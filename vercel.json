{
  "buildCommand": "pnpm --filter @workspace/tiktok-transfer build",
  "outputDirectory": "artifacts/tiktok-transfer/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "build": {
    "env": {
      "BASE_PATH": "/",
      "PORT": "3000"
    }
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
